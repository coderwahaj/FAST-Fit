<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootWorkoutList"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical">

    <!-- STATUS BAR SPACER (fixes overlap with time/battery on all themes) -->
    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:background="@color/fastfit_red" />

    <!-- Red header bar -->
    <TextView
        android:id="@+id/tvHeaderWorkoutList"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/fastfit_red"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/workout_list"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@android:color/white">

            <!-- ========== CARD 1: LEG PRESS ========== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/white">

                    <ImageView
                        android:id="@+id/imgLegPress"
                        android:layout_width="match_parent"
                        android:layout_height="170dp"
                        android:contentDescription="@string/leg_press"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_leg_press" />

                    <!-- FORCE white background where text + buttons are -->
                    <LinearLayout
                        android:id="@+id/legPressContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:background="@android:color/white">

                        <TextView
                            android:id="@+id/tvLegPressTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/leg_press"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvLegPressInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/leg_press_info"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btnBookLegPress"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/btn_red_rounded"
                                android:text="@string/book_slot"
                                android:textAllCaps="true"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <Space
                                android:layout_width="10dp"
                                android:layout_height="1dp" />

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btnWatchLegPress"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/btn_grey_rounded"
                                android:text="@string/watch_tutorial"
                                android:textAllCaps="true"
                                android:textColor="#111827"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ========== CARD 2: LAT PULLDOWN ========== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/white">

                    <ImageView
                        android:id="@+id/imgLatPulldown"
                        android:layout_width="match_parent"
                        android:layout_height="170dp"
                        android:contentDescription="@string/lat_pulldown"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_lat_pulldown" />

                    <LinearLayout
                        android:id="@+id/latPulldownContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:background="@android:color/white">

                        <TextView
                            android:id="@+id/tvLatPulldownTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/lat_pulldown"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvLatPulldownInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/lat_pulldown_info"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btnBookLatPulldown"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/btn_red_rounded"
                                android:text="@string/book_slot"
                                android:textAllCaps="true"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <Space
                                android:layout_width="10dp"
                                android:layout_height="1dp" />

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btnWatchLatPulldown"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/btn_grey_rounded"
                                android:text="@string/watch_tutorial"
                                android:textAllCaps="true"
                                android:textColor="#111827"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ========== CARD 3: CHEST PRESS ========== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/white">

                    <ImageView
                        android:id="@+id/imgChestPress"
                        android:layout_width="match_parent"
                        android:layout_height="170dp"
                        android:contentDescription="@string/chest_press"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_chest_press" />

                    <LinearLayout
                        android:id="@+id/chestPressContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:background="@android:color/white">

                        <TextView
                            android:id="@+id/tvChestPressTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chest_press"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvChestPressInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/chest_press_info"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btnBookChestPress"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/btn_red_rounded"
                                android:text="@string/book_slot"
                                android:textAllCaps="true"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <Space
                                android:layout_width="10dp"
                                android:layout_height="1dp" />

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btnWatchChestPress"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/btn_grey_rounded"
                                android:text="@string/watch_tutorial"
                                android:textAllCaps="true"
                                android:textColor="#111827"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>